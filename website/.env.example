# Auto-generated by terraform-setup (docker-compose)
# These are set at runtime via docker-compose env_file

# Client-side: uses Next.js rewrite proxy (same origin, no CORS)
NEXT_PUBLIC_API_URL=/api/proxy
# Server-side: target for the rewrite proxy
NEXT_PUBLIC_API_ENDPOINT=http://localhost:4566/restapis/<API_ID>/_user_request_
